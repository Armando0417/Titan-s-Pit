# Titan's Pit Ubuntu/Tailscale example
DATABASE_URL=local.db

HOST="0.0.0.0"
PORT="5823"
ORIGIN="http://your-server-name.tailnet.ts.net:5823"

# Copyparty runs on the same server.
COPYPARTY_BASE_URL="http://127.0.0.1:5822"
# Leave this empty for direct Tailscale access on port 5822.
COPYPARTY_PUBLIC_BASE_URL=""
COPYPARTY_ROOT_PATH="/"
COPYPARTY_TRASH_PATH="/_titans_pit_trash"

# These should match the Copyparty account in deploy/ubuntu/copyparty.env.
COPYPARTY_PASSWORD="replace-with-copyparty-password"
COPYPARTY_COOKIE=""
COPYPARTY_TIMEOUT_MS="8000"

# Generate a long random secret for the deployed app.
BETTER_AUTH_SECRET="replace-with-long-random-secret"
